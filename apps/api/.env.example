# ------------------------------------------------------------------
# Wudly API — environment variables
# Copy to `.env` for local development. Never commit real secrets.
# ------------------------------------------------------------------

# PostgreSQL connection string.
# Local dev (matches docker-compose.dev.yml — note host port 5433):
DATABASE_URL="postgresql://wudly:wudly@localhost:5433/wudly?schema=public"

# Secret used to sign JWT access tokens. Use a long random value in production.
JWT_SECRET="change-me-to-a-long-random-string"

# How long an access token stays valid.
JWT_EXPIRES_IN="7d"

# Allowed CORS origin(s) for the browser frontend (comma-separated).
CORS_ORIGIN="http://localhost:3000"

# Cookie domain (leave empty for localhost). Set in production if needed.
COOKIE_DOMAIN=""

# Set to "true" when served over HTTPS (production) so auth cookies are Secure.
COOKIE_SECURE="false"

NODE_ENV="development"
PORT="4000"

# Optional: bootstrap an admin account on seed.
SEED_ADMIN_EMAIL="admin@wudly.app"
SEED_ADMIN_PASSWORD="admin12345"

# AI provider. "dummy" = deterministic stub (no key needed). "openrouter" = real
# Gemini Flash 3.1 Lite via OpenRouter (falls back to dummy if the key is missing).
AI_PROVIDER="dummy"

# OpenRouter (only used when AI_PROVIDER=openrouter). Without a key the app still
# works and transparently falls back to the deterministic AI.
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="google/gemini-3.1-flash-lite"
OPENROUTER_SITE_URL="http://localhost:3000"
OPENROUTER_APP_TITLE="Wudly"

# Open Icecat — official manufacturer product data + images by EAN/GTIN.
# Register a free account at https://icecat.biz (Open Icecat). Without a
# username the lookup is skipped; the scan still uses the other free databases.
ICECAT_USERNAME=""
ICECAT_API_TOKEN=""
