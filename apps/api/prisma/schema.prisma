// Wudly — Prisma schema
// "Würdest du es wieder kaufen?" — real owner experiences after real usage.
//
// Enums here MUST stay in sync with packages/shared/src/enums.ts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/* ----------------------------------------------------------------- *
 * Enums
 * ----------------------------------------------------------------- */

enum UserRole {
  USER
  ADMIN
}

enum ProductStatus {
  ACTIVE
  PENDING_REVIEW
  MERGED
  HIDDEN
}

enum WouldBuyAgain {
  YES
  NO
  UNSURE
}

enum UsageDuration {
  LESS_THAN_WEEK
  ONE_TO_FOUR_WEEKS
  ONE_TO_SIX_MONTHS
  SIX_TO_TWELVE_MONTHS
  MORE_THAN_YEAR
}

enum ExperienceMood {
  TOP_BUY
  GOOD_DAILY_USE
  OKAY
  ANNOYING
  DEFECTIVE
  REGRET
  SURPRISINGLY_GOOD
}

enum AspectSentiment {
  POSITIVE
  NEGATIVE
  NEUTRAL
}

enum QuickAnswer {
  YES
  NO
  MOSTLY
  DEPENDS
  UNSURE
}

enum QuestionStatus {
  OPEN
  ANSWERED
  CLOSED
  HIDDEN
}

enum ProductPromptStatus {
  ACTIVE
  HIDDEN
}

enum VerificationStatus {
  SELF_DECLARED
  VERIFIED
  UNVERIFIED
}

enum ProductIdentifierType {
  EAN
  GTIN
  MPN
  ASIN
  SKU
  OTHER
}

enum ProductSourceType {
  USER_SUBMITTED
  MANUFACTURER
  IMPORT
  OTHER
}

enum CategoryAspectType {
  POSITIVE
  NEGATIVE
  NEUTRAL
}

enum MergeCandidateStatus {
  PENDING
  MERGED
  REJECTED
}

enum NotificationType {
  QUESTION_ASKED // a question was asked about a product you own
  QUESTION_ANSWERED // your question got an answer
  ANSWER_HELPFUL // your answer was marked helpful
  REBUY_REMINDER // 6-month "would you buy it again?" nudge
}

// --- Wudly Showcase (professional creator / brand content) ---
// Showcase content is clearly-labelled commercial material and NEVER feeds the
// neutral Wudly Signal score or the rankings.

enum ProfessionalProfileType {
  CREATOR
  INFLUENCER
  BRAND
  MERCHANT
  TESTER
}

enum ShowcaseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ShowcaseBlockType {
  HERO
  PROMISE
  AUDIENCE
  GALLERY
  FEATURE_CARDS
  USE_CASES
  PROBLEM_SOLUTION
  COMPARISON
  CHART
  FAQ
  VIDEO
  CREATOR_VERDICT
  BRAND_STATEMENT
  TECH_SPECS
  BUY_LINK
  AFFILIATE_NOTE
  DOWNLOADS
  CTA
  DISCLOSURE
}

enum DisclosureType {
  SELF_BOUGHT
  FREE_PRODUCT
  PAID_PARTNERSHIP
  AFFILIATE
  MANUFACTURER
  MERCHANT
  INDEPENDENT_TEST
  WUDLY_NATIVE
}

/// How an external rating value is expressed (drives display + normalization).
enum ExternalRatingKind {
  STARS // e.g. 4.5 of maxValue 5
  PERCENT // 0–100
  GRADE_DE // German school grade 1.0 (best) – 6.0 (worst), e.g. Stiftung Warentest
}

/* ----------------------------------------------------------------- *
 * Identity
 * ----------------------------------------------------------------- */

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  displayName  String?
  role         UserRole @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownerships        Ownership[]
  experienceReports ExperienceReport[]
  askedQuestions    ProductQuestion[]  @relation("AskedBy")
  answers           ProductAnswer[]
  badges            UserBadge[]
  notifications     Notification[]
  quickVotes        QuickVote[]
  createdProducts   Product[]          @relation("CreatedProducts")
  pushSubscriptions PushSubscription[]
  professionalProfile ProfessionalProfile?
  sentInvites         RatingInvite[]       @relation("SentInvites")
  claimedInvitedVotes InvitedVote[]        @relation("ClaimedInvitedVotes")
  promptResponses     ProductPromptResponse[]

  @@index([role])
}

/* ----------------------------------------------------------------- *
 * Catalog: products, variants, identifiers, sources
 * ----------------------------------------------------------------- */

model Category {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  createdAt DateTime @default(now())

  products  Product[]
  aspects   CategoryAspect[]
  templates ProductTemplate[]
}

model CategoryAspect {
  id         String             @id @default(cuid())
  categoryId String
  key        String
  label      String
  type       CategoryAspectType @default(NEUTRAL)
  createdAt  DateTime           @default(now())

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, key])
  @@index([categoryId])
}

model Product {
  id             String        @id @default(cuid())
  canonicalName  String
  normalizedName String
  brand          String?
  categoryId     String?
  description    String?
  imageUrl       String?
  /// Key→value technical facts (model, color, dimensions, …) gathered from
  /// external catalogs (Icecat/UPCitemdb). Order-preserving array of pairs.
  specs          Json          @default("[]")
  status         ProductStatus @default(ACTIVE)
  createdByUserId String?
  /// When the owner/buyer question pool was first generated (null = not yet).
  /// Gates one-time generation so the AI is asked at most once per product.
  promptsGeneratedAt DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  category  Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy User?     @relation("CreatedProducts", fields: [createdByUserId], references: [id], onDelete: SetNull)

  variants          ProductVariant[]
  identifiers       ProductIdentifier[]
  sources           ProductSource[]
  ownerships        Ownership[]
  experienceReports ExperienceReport[]
  questions         ProductQuestion[]
  answers           ProductAnswer[]
  quickVotes        QuickVote[]
  insightSnapshot   ProductInsightSnapshot?
  aliasesFrom       ProductAlias[]          @relation("CanonicalProduct")
  aliasAsOld        ProductAlias?           @relation("OldProduct")
  mergeCandidatesA  AdminMergeCandidate[]   @relation("ProductA")
  mergeCandidatesB  AdminMergeCandidate[]   @relation("ProductB")
  showcases         ProductShowcase[]
  externalRatings   ExternalRating[]
  externalConsensus ExternalConsensus?
  cachedImage       ProductImage?
  ratingInvites     RatingInvite[]
  invitedVotes      InvitedVote[]
  prompts           ProductPrompt[]
  promptResponses   ProductPromptResponse[]

  @@index([normalizedName])
  @@index([categoryId])
  @@index([status])
  @@index([brand])
  @@index([createdByUserId])
}

model ProductVariant {
  id         String   @id @default(cuid())
  productId  String
  name       String?
  attributes Json     @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  product           Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  identifiers       ProductIdentifier[]
  ownerships        Ownership[]
  experienceReports ExperienceReport[]

  @@index([productId])
}

model ProductIdentifier {
  id        String                @id @default(cuid())
  productId String
  variantId String?
  type      ProductIdentifierType
  value     String
  source    String?
  createdAt DateTime              @default(now())

  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([type, value])
  @@index([productId])
}

/// Aggregated rating FACTS from other platforms (average + count + link), shown
/// in a clearly-labelled "Bewertungen anderswo" section. Facts only — never
/// copied review texts, and NEVER part of the Wudly Signal score or rankings.
model ExternalRating {
  id          String             @id @default(cuid())
  productId   String
  /// Stable machine key of the source, e.g. "amazon", "idealo", "warentest".
  source      String
  /// Display name, e.g. "Amazon".
  sourceLabel String
  /// Attribution link — an external fact is only shown with its source.
  url         String
  kind        ExternalRatingKind @default(STARS)
  value       Float
  /// Scale maximum (5 for stars, 100 for percent; ignored for GRADE_DE).
  maxValue    Float              @default(5)
  /// Number of ratings behind the value (null when the source doesn't say).
  count       Int?
  /// Free-text context, e.g. "Heft 5/2024".
  note        String?
  /// When the value was last read from the source.
  fetchedAt   DateTime           @default(now())
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, source])
  @@index([productId])
}

/// Source-backed themes distilled from public reviews and long-term reports.
/// Orientation only: never contributes to the Wudly Signal or rankings.
model ExternalConsensus {
  id             String   @id @default(cuid())
  productId      String   @unique
  summary        String?
  positiveThemes Json     @default("[]")
  negativeThemes Json     @default("[]")
  sourceUrls     Json     @default("[]")
  fetchedAt      DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([fetchedAt])
}

/// Cached product image bytes (downloaded once from Icecat / EAN databases /
/// camera capture). Serving from our own DB keeps thumbnails stable and uniform
/// instead of hotlinking external URLs that rot or vary in quality.
model ProductImage {
  id        String   @id @default(cuid())
  productId String   @unique
  mime      String
  bytes     Bytes
  /// Where the image was downloaded from (null for inline/manual uploads).
  sourceUrl String?
  /// Provider key: icecat | openfoodfacts | upcitemdb | photo | manual.
  source    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductSource {
  id              String            @id @default(cuid())
  productId       String
  sourceType      ProductSourceType
  sourceUrl       String?
  externalId      String?
  rawTitle        String?
  matchConfidence Float             @default(0)
  createdAt       DateTime          @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

/* ----------------------------------------------------------------- *
 * Ownership & experiences
 * ----------------------------------------------------------------- */

model Ownership {
  id                 String             @id @default(cuid())
  userId             String
  productId          String
  variantId          String?
  verificationStatus VerificationStatus @default(SELF_DECLARED)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  // When the 6-month rebuy reminder was sent (null = not yet). Avoids re-sending.
  reminderSentAt     DateTime?

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  experienceReports ExperienceReport[]

  @@unique([userId, productId])
  @@index([productId])
  @@index([userId])
}

model ExperienceReport {
  id             String         @id @default(cuid())
  userId         String
  productId      String
  variantId      String?
  ownershipId    String?
  wouldBuyAgain  WouldBuyAgain
  usageDuration  UsageDuration
  experienceMood ExperienceMood
  wishKnownText  String?
  freeText       String?
  // Comparative regret: what the owner wishes they'd bought instead (free text).
  insteadOfText  String?
  isPublic       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  ownership Ownership?      @relation(fields: [ownershipId], references: [id], onDelete: SetNull)

  aspects         ExperienceAspect[]
  promptResponses ProductPromptResponse[]

  @@index([productId])
  @@index([userId])
  @@index([productId, isPublic])
}

model ExperienceAspect {
  id                 String          @id @default(cuid())
  experienceReportId String
  aspectKey          String
  sentiment          AspectSentiment
  severity           Int?
  createdAt          DateTime        @default(now())

  experienceReport ExperienceReport @relation(fields: [experienceReportId], references: [id], onDelete: Cascade)

  @@index([experienceReportId])
  @@index([aspectKey])
}

/// Lightweight swipe-deck signal ("würdest du es wieder kaufen?") captured without
/// the full experience form. Deduped per (product, user); anonymous votes allowed.
model QuickVote {
  id        String        @id @default(cuid())
  productId String
  userId    String?
  value     WouldBuyAgain
  tags      String[]      @default([])
  createdAt DateTime      @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([productId, userId])
  @@index([productId])
  @@index([userId])
}

/* ----------------------------------------------------------------- *
 * Questions & answers
 * ----------------------------------------------------------------- */

model ProductQuestion {
  id            String         @id @default(cuid())
  productId     String
  askedByUserId String?
  questionText  String
  status        QuestionStatus @default(OPEN)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  askedBy   User?   @relation("AskedBy", fields: [askedByUserId], references: [id], onDelete: SetNull)

  answers ProductAnswer[]

  @@index([productId])
  @@index([status])
}

model ProductAnswer {
  id               String       @id @default(cuid())
  questionId       String
  productId        String
  answeredByUserId String
  answerText       String
  quickAnswer      QuickAnswer?
  helpfulCount     Int          @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  question   ProductQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  product    Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  answeredBy User            @relation(fields: [answeredByUserId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@index([productId])
}

/* ----------------------------------------------------------------- *
 * Owner/buyer question pool — a stored, product-specific set of sharp
 * questions WITH quick answers. Generated once (AI) or grown by users, then
 * reused everywhere: the owner answers them fast in the "Ich besitze es"
 * wizard, a buyer picks them as ask-suggestions, and the product page shows
 * the aggregated owner answers. Strictly product-knowledge — never the Signal.
 * ----------------------------------------------------------------- */

model ProductPrompt {
  id           String              @id @default(cuid())
  productId    String
  questionText String
  /// Suggested short answers, order-preserving: ["Sehr leise","Okay","Zu laut"].
  /// Owners may add their own; accepted custom answers are appended here so the
  /// pool learns over time. Empty array = open question (free text only).
  quickAnswers Json                @default("[]")
  /// Where this prompt came from: ai | curated | user.
  source       String              @default("ai")
  sortOrder    Int                 @default(0)
  /// Denormalized count of owner responses (drives "meistbeantwortet zuerst").
  responseCount Int                @default(0)
  status       ProductPromptStatus @default(ACTIVE)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  product   Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  responses ProductPromptResponse[]

  @@index([productId, status])
}

/// One owner's answer to a prompt — a chosen quick answer OR their own text.
/// Created inside the "Ich besitze es" wizard, optionally tied to the same
/// experience report. Deduped per (prompt, user) so re-answering updates.
model ProductPromptResponse {
  id                 String   @id @default(cuid())
  promptId           String
  productId          String
  userId             String
  experienceReportId String?
  answerLabel        String
  /// True when the owner typed their own answer instead of picking an option.
  isCustom           Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  prompt           ProductPrompt     @relation(fields: [promptId], references: [id], onDelete: Cascade)
  product          Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  experienceReport ExperienceReport? @relation(fields: [experienceReportId], references: [id], onDelete: SetNull)

  @@unique([promptId, userId])
  @@index([promptId])
  @@index([productId])
}

/* ----------------------------------------------------------------- *
 * Derived insights (snapshot per product)
 * ----------------------------------------------------------------- */

model ProductInsightSnapshot {
  id                  String   @id @default(cuid())
  productId           String   @unique
  ownerCount          Int      @default(0)
  experienceCount     Int      @default(0)
  rebuyScore          Int?
  regretScore         Int?
  unsureScore         Int?
  topPositiveAspects  Json     @default("[]")
  topNegativeAspects  Json     @default("[]")
  wishKnownHighlights Json     @default("[]")
  usageDurationStats  Json     @default("{}")
  // Comparative regret: share (0–100) who named an alternative + the top names.
  insteadOfShare      Int      @default(0)
  insteadOfHighlights Json     @default("[]")
  // "Wudly-empfohlen" seal — auto-awarded, recomputed with every snapshot.
  wudlySeal           Boolean  @default(false)
  // Cached "Netz-Konsens": average of external ratings normalized to 0–100, plus
  // how many sources back it. NOT part of the Wudly Signal — purely external facts,
  // precomputed here so product cards don't have to join ExternalRating per render.
  externalAvgPercent  Int?
  externalSourceCount Int      @default(0)
  // AI-generated summary (OpenRouter). Null until generated / when AI is disabled.
  aiHeadline          String?
  aiSuitedFor         Json     @default("[]")
  aiNotSuitedFor      Json     @default("[]")
  aiGeneratedAt       DateTime?
  generatedAt         DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([rebuyScore])
  @@index([regretScore])
  @@index([experienceCount])
}

/* ----------------------------------------------------------------- *
 * Web Push — device subscriptions so notifications reach users off-app
 * ----------------------------------------------------------------- */

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/* ----------------------------------------------------------------- *
 * Notifications — close the Q&A loop (owner gets asked, asker gets answered)
 * ----------------------------------------------------------------- */

model Notification {
  id         String           @id @default(cuid())
  userId     String
  type       NotificationType
  title      String
  body       String?
  // Where tapping the notification takes the user (e.g. /products/<id>).
  link       String?
  // Loose references to the entities involved — no FK so deletes don't cascade away history.
  productId  String?
  questionId String?
  readAt     DateTime?
  createdAt  DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

/* ----------------------------------------------------------------- *
 * Gamification
 * ----------------------------------------------------------------- */

model Badge {
  id          String      @id @default(cuid())
  key         String      @unique
  label       String
  description String
  users       UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
}

/* ----------------------------------------------------------------- *
 * Admin: product dedupe / merge tooling
 * ----------------------------------------------------------------- */

model AdminMergeCandidate {
  id         String               @id @default(cuid())
  productAId String
  productBId String
  score      Float
  reason     String?
  status     MergeCandidateStatus @default(PENDING)
  createdAt  DateTime             @default(now())
  resolvedAt DateTime?

  productA Product @relation("ProductA", fields: [productAId], references: [id], onDelete: Cascade)
  productB Product @relation("ProductB", fields: [productBId], references: [id], onDelete: Cascade)

  @@unique([productAId, productBId])
  @@index([status])
}

model ProductAlias {
  id                 String   @id @default(cuid())
  oldProductId       String   @unique
  canonicalProductId String
  reason             String?
  createdAt          DateTime @default(now())

  oldProduct       Product @relation("OldProduct", fields: [oldProductId], references: [id], onDelete: Cascade)
  canonicalProduct Product @relation("CanonicalProduct", fields: [canonicalProductId], references: [id], onDelete: Cascade)

  @@index([canonicalProductId])
}

/* ----------------------------------------------------------------- *
 * Wudly Showcase — professional creator / brand product presentation.
 *
 * These tables hold clearly-labelled COMMERCIAL / CREATOR content. They are
 * intentionally separate from the Signal tables (experiences, insights) and
 * must NEVER be read into the score or the rankings.
 * ----------------------------------------------------------------- */

/// A professional profile (creator, influencer, brand, merchant, tester).
/// One per user; the public page lives at /creator/:slug.
model ProfessionalProfile {
  id                 String                  @id @default(cuid())
  userId             String                  @unique
  type               ProfessionalProfileType
  displayName        String
  slug               String                  @unique
  logoUrl            String?
  bio                String?
  websiteUrl         String?
  socialLinks        Json                    @default("{}")
  verificationStatus VerificationStatus      @default(SELF_DECLARED)
  /// Self-declared: this profile may publish paid cooperations.
  paidPartnerships   Boolean                 @default(false)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  showcases ProductShowcase[]

  @@index([type])
}

/// A professional product landing page built from blocks. Always attributed to
/// a profile and always carries a disclosure type.
model ProductShowcase {
  id                  String         @id @default(cuid())
  productId           String
  profileId           String
  title               String
  subtitle            String?
  status              ShowcaseStatus @default(DRAFT)
  disclosureType      DisclosureType
  /// Free-text disclosure detail (e.g. "Enthält Affiliate-Links zu Amazon").
  affiliateDisclosure String?
  publishedAt         DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  product Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  profile ProfessionalProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  blocks  ShowcaseBlock[]

  @@index([productId, status])
  @@index([profileId])
}

/// One content block of a showcase. The `content` JSON shape depends on `type`.
model ShowcaseBlock {
  id         String            @id @default(cuid())
  showcaseId String
  type       ShowcaseBlockType
  sortOrder  Int               @default(0)
  content    Json              @default("{}")
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  showcase ProductShowcase @relation(fields: [showcaseId], references: [id], onDelete: Cascade)

  @@index([showcaseId, sortOrder])
}

/// A reusable, category-specific starting point for a showcase (block layout +
/// suggested comparison criteria). Seeded by admins.
model ProductTemplate {
  id          String   @id @default(cuid())
  categoryId  String?
  slug        String   @unique
  name        String
  description String?
  /// Array of { type, content } block presets, plus suggested criteria.
  blocks      Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([categoryId])
}

/* ----------------------------------------------------------------- *
 * Invite-to-rate — ask an acquaintance to rate a product they own,
 * without an account. Guest voices are clearly marked and weighted DOWN
 * in the Signal; they can be upgraded to a full vote on login/register.
 * ----------------------------------------------------------------- */

/// A shareable invite link for a specific product. Optionally capped + expiring.
model RatingInvite {
  id            String    @id @default(cuid())
  token         String    @unique
  productId     String
  inviterUserId String?
  maxUses       Int       @default(1)
  uses          Int       @default(0)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())

  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  inviter User?         @relation("SentInvites", fields: [inviterUserId], references: [id], onDelete: SetNull)
  votes   InvitedVote[]

  @@index([productId])
  @@index([inviterUserId])
}

/// A rating left via an invite link (no, or not-yet, account). Marked as an
/// invited voice and weighted DOWN in the signal; `claimedByUserId` upgrades it
/// to a full vote once the guest logs in or registers.
model InvitedVote {
  id              String        @id @default(cuid())
  inviteId        String?
  productId       String
  guestName       String?
  wouldBuyAgain   WouldBuyAgain
  comment         String?
  /// Signal weight 0..1 (guest votes count less than verified owner experiences).
  weight          Float         @default(0.4)
  claimedByUserId String?
  createdAt       DateTime      @default(now())

  invite    RatingInvite? @relation(fields: [inviteId], references: [id], onDelete: SetNull)
  product   Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  claimedBy User?         @relation("ClaimedInvitedVotes", fields: [claimedByUserId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([inviteId])
  @@index([claimedByUserId])
}

