{
  "name": "@wudly/api",
  "version": "0.1.0",
  "private": true,
  "description": "Wudly REST API — NestJS + Prisma + PostgreSQL.",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/src/main.js",
    "start:prod": "node dist/src/main.js",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit --tsBuildInfoFile node_modules/.cache/tsc-typecheck.tsbuildinfo",
    "typecheck:scripts": "tsc -p tsconfig.scripts.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:reset": "prisma migrate reset --force",
    "prisma:seed": "tsx prisma/seed.ts",
    "seed:pulse-demo": "tsx prisma/seed-pulse-demo.ts",
    "cleanup:seed": "tsx prisma/cleanup-seed.ts",
    "resync:snapshots": "tsx prisma/resync-snapshots.ts",
    "benchmark:product-search": "tsx scripts/benchmark-product-search.ts",
    "benchmark:sonar": "tsx scripts/benchmark-sonar-vs-search-gemini.ts",
    "catalog:rebuild-researched": "tsx scripts/rebuild-researched-catalog.ts",
    "catalog:agent:research": "tsx scripts/agent-product-curation.ts",
    "catalog:agent:import": "tsx scripts/agent-product-curation.ts --commit",
    "catalog:import:research": "tsx scripts/agent-product-import.ts",
    "prisma:studio": "prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.15",
    "@prisma/client": "^6.2.1",
    "@wudly/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.0.0",
    "prisma": "^6.2.1",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.16.0",
    "rxjs": "^7.8.1",
    "web-push": "^3.6.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/supertest": "^6.0.2",
    "@types/web-push": "^3.6.4",
    "@wudly/config": "workspace:*",
    "eslint": "^9.18.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "unplugin-swc": "^1.5.1",
    "vitest": "^2.1.8"
  }
}
