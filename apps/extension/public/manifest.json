{
  "manifest_version": 3,
  "name": "Wudly Signal",
  "version": "0.1.0",
  "description": "Das ehrliche Besitzer-Urteil direkt beim Shoppen — Wiederkauf-Quote und Netz-Konsens auf der Produktseite.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://wudly-api-production.up.railway.app/*",
    "http://localhost:4000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.de/*",
        "https://amazon.de/*",
        "https://www.mediamarkt.de/*",
        "https://www.saturn.de/*",
        "https://www.otto.de/*",
        "https://www.kaufland.de/*",
        "https://www.cyberport.de/*",
        "https://www.alternate.de/*",
        "https://www.galaxus.de/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Wudly Signal",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
