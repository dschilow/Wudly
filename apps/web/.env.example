# ------------------------------------------------------------------
# Wudly Web — environment variables
# Copy to `.env.local` for local development.
# ------------------------------------------------------------------

# Base URL of the Wudly API, INCLUDING the /api prefix.
# Local dev:
NEXT_PUBLIC_API_URL="http://localhost:4000/api"

# On Railway this points to the public api service URL, e.g.:
# NEXT_PUBLIC_API_URL="https://wudly-api-production.up.railway.app/api"

# Optional: server-side API URL for SSR/RSC fetches when it differs from the
# public one (e.g. Railway private networking). Falls back to NEXT_PUBLIC_API_URL.
# API_URL_INTERNAL="http://wudly-api.railway.internal:4000/api"
