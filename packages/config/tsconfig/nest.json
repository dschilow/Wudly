{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Wudly NestJS",
  "extends": "./base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "lib": ["ES2022"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "declaration": false,
    "declarationMap": false,
    "noEmit": false,
    "strictPropertyInitialization": false
  }
}
