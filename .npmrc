# Wudly uses the public npm registry. The corporate registry from the user's
# global ~/.npmrc is not reachable for these public OSS packages, so we override
# the default registry here (project scope only — global config is untouched).
registry=https://registry.npmjs.org/

# Keep the @beckhoff scope on the corporate feed in case it is ever needed here.
@beckhoff:registry=https://azdevops01.beckhoff.com/GSW01/_packaging/TcBase/npm/registry/

auto-install-peers=true
strict-peer-dependencies=false

# React Native / Metro (apps/mobile) can't follow pnpm's symlinked, isolated
# node_modules for Babel's injected runtime helpers. Hoist @babel/runtime to the
# root node_modules so Metro's plain resolver finds it. Scoped to this one
# package to avoid changing dependency resolution for api/web.
public-hoist-pattern[]=@babel/runtime
