# ==================================================================
# Wudly — root reference for all environment variables.
# Per-app examples live in apps/api/.env.example and apps/web/.env.example.
# Copy the relevant block to the matching app's .env / .env.local.
# ==================================================================

# ----- Shared / local Postgres (docker-compose.dev.yml) -----
# Host port 5433 avoids clashing with a local 5432 Postgres.
DATABASE_URL="postgresql://wudly:wudly@localhost:5433/wudly?schema=public"

# ----- apps/api (NestJS backend) -----
JWT_SECRET="change-me-to-a-long-random-string-min-16-chars"
JWT_EXPIRES_IN="7d"
CORS_ORIGIN="http://localhost:3000"
COOKIE_DOMAIN=""
COOKIE_SECURE="false"
NODE_ENV="development"
PORT="4000"
AI_PROVIDER="dummy"
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="google/gemini-3.1-flash-lite"
OPENROUTER_SITE_URL="http://localhost:3000"
OPENROUTER_APP_TITLE="Wudly"
# Product research retrieval. "openrouter" + "perplexity" uses Perplexity
# Search API through OpenRouter while Gemini still performs JSON extraction.
PRODUCT_RESEARCH_SEARCH_PROVIDER="openrouter"
OPENROUTER_WEB_SEARCH_ENGINE="perplexity"
OPENROUTER_WEB_SEARCH_MAX_RESULTS="5"
OPENROUTER_WEB_SEARCH_EXCLUDE_DOMAINS="youtube.com,ebay.com,ebay.de,allegro.pl,trustpilot.com"
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="gemma4:e4b"
SEED_ADMIN_EMAIL="admin@wudly.app"
SEED_ADMIN_PASSWORD="admin12345"
# Open Icecat (official titles/photos/specs by EAN) — free account at icecat.biz.
ICECAT_USERNAME=""
ICECAT_API_TOKEN=""
# Google Programmable Search (image mode) — best photo source for products no
# EAN database covers; 100 queries/day free. Setup:
#   1. console.cloud.google.com → enable "Custom Search API" → create API key
#   2. programmablesearchengine.google.com → new engine, "Search entire web",
#      image search ON → copy the "cx" id
GOOGLE_CSE_KEY=""
GOOGLE_CSE_ID=""
# Brave web grounding and product benchmark comparison.
BRAVE_SEARCH_KEY=""
# Web Push (VAPID). Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:hallo@wudly.app"

# ----- apps/web (Next.js frontend) -----
# Must include the /api prefix.
NEXT_PUBLIC_API_URL="http://localhost:4000/api"

# ==================================================================
# Railway production values (set per service in the Railway dashboard):
#
#   wudly-postgres : Railway-managed PostgreSQL plugin
#
#   wudly-api:
#     DATABASE_URL = ${{Postgres.DATABASE_URL}}
#     JWT_SECRET   = <generate a long random secret>
#     CORS_ORIGIN  = https://<your-web-domain>
#     COOKIE_SECURE = true
#     NODE_ENV     = production
#     PORT         = (provided by Railway automatically)
#     AI_PROVIDER  = openrouter
#     OPENROUTER_API_KEY = <OpenRouter key>
#     OPENROUTER_MODEL = google/gemini-3.1-flash-lite
#     OPENROUTER_SITE_URL = https://<your-web-domain>
#     OPENROUTER_APP_TITLE = Wudly
#     # Gemma 4 E4B test mode instead of OpenRouter:
#     # AI_PROVIDER = ollama
#     # OLLAMA_BASE_URL = http://wudly-gemma.railway.internal:11434
#     # OLLAMA_MODEL = gemma4:e4b
#     # OLLAMA_BASE_URL = http://wudly-gemma-e2b.railway.internal:11434
#     # OLLAMA_MODEL = gemma4:e2b
#     ICECAT_USERNAME = <optional Open Icecat username>
#     GOOGLE_CSE_KEY / GOOGLE_CSE_ID = <optional image search>
#     VAPID_PUBLIC_KEY / VAPID_PRIVATE_KEY / VAPID_SUBJECT = <optional web push>
#
#   wudly-web:
#     NEXT_PUBLIC_API_URL = https://<your-api-domain>/api
#
#   wudly-gemma:
#     GEMMA_MODEL = gemma4:e4b
#     OLLAMA_KEEP_ALIVE = 30m
#     PORT = 11434
#     RAILWAY_DOCKERFILE_PATH = apps/gemma/Dockerfile
#   wudly-gemma-e2b:
#     GEMMA_MODEL = gemma4:e2b
#     OLLAMA_KEEP_ALIVE = 30m
#     PORT = 11434
#     RAILWAY_DOCKERFILE_PATH = apps/gemma/Dockerfile
#     Volume mount: /root/.ollama
# ==================================================================
